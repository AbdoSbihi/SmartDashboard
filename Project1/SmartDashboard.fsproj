<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>SmartDashboard</AssemblyName>
    <RootNamespace>SmartDashboard</RootNamespace>
    <WebSharperProject>spa</WebSharperProject>
    <WebSharperConfigFile>wsconfig.json</WebSharperConfigFile>
    <WebSharperSourceGenerators>false</WebSharperSourceGenerators>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="Model.fs" />
    <Compile Include="Server.fs" />
    <Compile Include="Client.fs" />
    <Compile Include="Site.fs" />
    <Compile Include="Startup.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="WebSharper"            Version="10.0.0.652" />
    <PackageReference Include="WebSharper.UI"         Version="10.0.0.652" />
    <PackageReference Include="WebSharper.AspNetCore" Version="10.0.0.652" />
    <PackageReference Include="WebSharper.FSharp"     Version="10.0.0.652" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Main.html">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>